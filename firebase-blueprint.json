{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "createdAt"]
    },
    "Report": {
      "title": "Skin Analysis Report",
      "description": "A report generated after skin analysis",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "overallScore": { "type": "number" },
        "acneScore": { "type": "number" },
        "glowScore": { "type": "number" },
        "hydrationScore": { "type": "number" },
        "youthScore": { "type": "number" },
        "skinAge": { "type": "number" },
        "issuesDetected": { "type": "array", "items": { "type": "string" } },
        "remedies": { "type": "array", "items": { "type": "string" } },
        "routine": { "type": "array", "items": { "type": "string" } },
        "diet": { "type": "array", "items": { "type": "string" } },
        "lifestyle": { "type": "array", "items": { "type": "string" } },
        "products": { "type": "array", "items": { "type": "string" } },
        "summary": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "overallScore", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "reports/{reportId}": {
      "schema": "Report",
      "description": "Individual skin analysis reports"
    }
  }
}
